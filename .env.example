# ===========================================
# Lagrange.RagBot 环境变量示例
# 复制此文件为 .env 并填入实际值
# ===========================================

# ---------- Lagrange 连接配置 ----------
# 正向 WebSocket（Forward WebSocket）
# 用于连接已在局域网/本机运行的 Lagrange 正向 WS 服务
LAGRANGE_WS_TYPE=forward-websocket
LAGRANGE_WS_HOST=192.168.10.1
LAGRANGE_WS_PORT=3001
LAGRANGE_WS_ACCESS_TOKEN=

# 反向 WebSocket 时使用（可选）
# LAGRANGE_WS_TYPE=backward-websocket
# LAGRANGE_WS_PATH=/onebot/v11/ws

# 数据库目录（仅在不使用 configPath 时作为 LAGRANGE_CORE_HOME 的 fallback）
# LAGRANGE_CORE_HOME=

# 授权用户 QQ 号，逗号分隔
AUTHORIZED_USERS=1193466151

# ---------- TIP HTTP 服务端口（可选，默认 3021）----------
# PORT=3021

# ---------- OpenAI / LLM ----------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=gpt-4o

DEEPSEEK_API_TOKEN=xxx

OMCP_DISCORD_SERVER_IP=
OMCP_DISCORD_SERVER_PORT=
OMCP_DISCORD_TOKEN=

# ES_PASSWORD=
